# Dynamic Wallet
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# LI.FI
NEXT_PUBLIC_LIFI_API_KEY=

# Agent Auth
AGENT_API_SECRET=
AGENT_CONFIG_CIPHER_KEY=
CLI_TOKEN_TTL_DAYS=30
CRON_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Agent config
AGENT_CURRENT_CHAIN_ID=42161
AGENT_POSITION_USDC=100
AUTO_REBALANCE_ENABLED=false
AGENT_PRIVATE_KEY=

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH

# Terminal 3 T3N Agent Auth
# 1. Sign up at https://terminal3.io/claim-page to get API key + DID
# 2. Set T3N_AGENT_API_KEY and T3N_AGENT_DID
# 3. T3N_OPERATOR_ADDRESS is your Ethereum address (the "human operator")
# 4. Call POST /api/t3n/authorize to issue a signed bridge authorization
# 5. Set T3N_BRIDGE_AUTH to the serialized credential from that response
T3N_AGENT_API_KEY=
T3N_AGENT_DID=
T3N_OPERATOR_ADDRESS=
T3N_BASE_URL=https://testnet.terminal3.io
T3N_BRIDGE_AUTH=
